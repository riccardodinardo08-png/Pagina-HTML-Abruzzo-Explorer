function showPage(id){
document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
document.getElementById(id).classList.add('active');

if(id==="map"){
setTimeout(()=>{ if(window.map) window.map.invalidateSize(); },300);
initMap();
}
}

/* MAP */
let mapLoaded=false;

function initMap(){
if(mapLoaded) return;
mapLoaded=true;

window.map = L.map('mapBox').setView([42.35,13.40],8);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
attribution:'OpenStreetMap'
}).addTo(window.map);

L.marker([42.35,13.40]).addTo(window.map).bindPopup("Gran Sasso");
L.marker([42.08,13.93]).addTo(window.map).bindPopup("Parco Nazionale d'Abruzzo");
L.marker([42.35,13.40]).addTo(window.map).bindPopup("L'Aquila");
}

